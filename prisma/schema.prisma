generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  name        String?
  role        String   @default("PLAYER")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile          Profile?
  squads           Squad[]
  homeFixtures     Fixture[] @relation("HomeFixtures")
  awayFixtures     Fixture[] @relation("AwayFixtures")
  submittedResults Result[]
  leagueEntries    LeagueEntry[]
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  awards           Award[]
  hallOfFame       HallOfFame[]
  news             News[]
  tournaments      TournamentParticipant[]
  homeTournamentMatches TournamentMatch[] @relation("HomeMatches")
  awayTournamentMatches TournamentMatch[] @relation("AwayMatches")
  winnerTournamentMatches TournamentMatch[] @relation("WinnerMatches")
  auditLogs        AuditLog[]
  notifications Notification[]  // ADD THIS LINE
    lastActive     DateTime?
  isVerified     Boolean  @default(false)
  verifiedAt     DateTime?
  verifiedBy     String?
  settings    Setting[]
    // ✅ ADD THESE TWO LINES:
  backups     Backup[]
  restoreLogs RestoreLog[]
   // ✅ ADD THESE NEW FIELDS:
  // Email Verification
  emailVerified             Boolean   @default(false)
  emailVerifiedAt           DateTime?
  emailVerificationToken    String?   @unique
  emailVerificationSentAt   DateTime?

  // Password Reset
  resetPasswordToken        String?   @unique
  resetPasswordSentAt       DateTime?
  resetPasswordExpiresAt    DateTime?

  // Email Preferences
  emailNotificationsEnabled Boolean   @default(false)
  notificationPreferences   Json?
  lastEmailSentAt           DateTime?
  // ✅ Add these for reports
  reportsAsReporter    Report[] @relation("ReportReporter")    // Reports this user made
  reportsAsReported    Report[] @relation("ReportReportedUser") // Reports against this user
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  username            String   @unique
  class               String?
  bio                 String?  @db.Text
  favoriteClub        String?
  preferredFormation  String?
  preferredPlaystyle  String?
  profilePicture      String?
  bannerImage         String?
 whatsappNumber      String?   // ADD THIS LINE
  whatsappVisible     Boolean   @default(true)  // ADD THIS LINE
  totalPoints         Int      @default(0)
  totalWins           Int      @default(0)
  totalDraws          Int      @default(0)
  totalLosses         Int      @default(0)
  goalsFor            Int      @default(0)
  goalsAgainst        Int      @default(0)
  goalDifference      Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerStats PlayerStats?
    timezone        String?  @default("Africa/Nairobi")
  availableFrom   String?  // e.g., "19:00"
  availableTo     String?  // e.g., "23:00"
    verifiedBadge  Boolean  @default(false)
  trustScore     Int      @default(0)
}


model PlayerStats {
  id            String  @id @default(cuid())
  profileId     String  @unique
  seasonId      String
  goals         Int     @default(0)
  assists       Int     @default(0)
  cleanSheets   Int     @default(0)
  manOfTheMatch Int     @default(0)
  matchesPlayed Int     @default(0)
  winRate       Float   @default(0)

  profile Profile @relation(fields: [profileId], references: [id])
}

model Season {
  id          String        @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      SeasonStatus  @default(PRESEASON)
  isActive    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  leagueEntries LeagueEntry[]
  fixtures      Fixture[]
  awards        Award[]
  hallOfFame    HallOfFame[]
  tournaments   Tournament[]  // ✅ This requires Tournament model
}

// ✅ ADD THIS MODEL HERE (after Season, before TournamentMatch)
model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?
  seasonId    String?
  type        TournamentType   @default(SINGLE_ELIM)
  status      TournamentStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime
  maxPlayers  Int              @default(8)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  season       Season?                    @relation(fields: [seasonId], references: [id])
  participants TournamentParticipant[]
  matches      TournamentMatch[]
}

// Then TournamentMatch and TournamentParticipant come after

model Fixture {
  id            String   @id @default(cuid())
  seasonId      String
  homePlayerId  String
  awayPlayerId  String
  scheduledDate DateTime
  homeScore     Int?
  awayScore     Int?
  status        String   @default("SCHEDULED")  // ADD THIS LINE
  submittedBy   String?
  submittedAt   DateTime?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  season     Season   @relation(fields: [seasonId], references: [id])
  homePlayer User     @relation("HomeFixtures", fields: [homePlayerId], references: [id])
  awayPlayer User     @relation("AwayFixtures", fields: [awayPlayerId], references: [id])
  result     Result?
   // ✅ Add these fields for time suggestions
  proposedDate     DateTime?
  proposedBy       String?
  schedulingStatus String   @default("PENDING") // PENDING, PROPOSED, CONFIRMED, REJECTED
  schedulingNotes  String?  @db.Text
}

model Result {
  id            String   @id @default(cuid())
  fixtureId     String?  @unique
  homeScore     Int
  awayScore     Int
  evidenceImage String?
  submittedBy   String
  approved      Boolean  @default(false)
  source        String   @default("LEAGUE")  // ✅ "LEAGUE" or "TOURNAMENT"
  createdAt     DateTime @default(now())

  fixture Fixture? @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [submittedBy], references: [id])
  
  tournamentMatch   TournamentMatch? @relation(fields: [tournamentMatchId], references: [id])
  tournamentMatchId String?          @unique
}


model LeagueEntry {
  id             String   @id @default(cuid())
  seasonId       String
  playerId       String
  played         Int      @default(0)
  wins           Int      @default(0)
  draws          Int      @default(0)
  losses         Int      @default(0)
  goalsFor       Int      @default(0)
  goalsAgainst   Int      @default(0)
  goalDifference Int      @default(0)
  points         Int      @default(0)

  season Season @relation(fields: [seasonId], references: [id])
  player User   @relation(fields: [playerId], references: [id])

  @@unique([seasonId, playerId])
}

model Squad {
  id           String     @id @default(cuid())
  userId       String
  type         SquadType  @default(MAIN)
  screenshot   String
  formation    String
  teamStrength Int
  playstyle    String
  seasonId     String?
  isActive     Boolean    @default(false)
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
 status       String     @default("APPROVED") // ✅ ADD THIS LINE
  user User @relation(fields: [userId], references: [id])
}

model Post {
  id        String    @id @default(cuid())
  userId    String
  content   String    @db.Text
  image     String?
   status    String    @default("APPROVED")  // ✅ ADD THIS LINE
  type      PostType  @default(GENERAL)
  likes     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]
  likes_rel Like[]
  reports  Report[]  // ✅ ADD THIS LINE
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Award {
  id                String   @id @default(cuid())
  seasonId          String
  name              String
  category          String   @default("CUSTOM")
  icon              String?
  winnerId          String
  description       String?  @db.Text
  awardedAt         DateTime @default(now())
  isAutoGenerated   Boolean  @default(false)

  season Season @relation(fields: [seasonId], references: [id])
  winner User   @relation(fields: [winnerId], references: [id])

  @@unique([seasonId, category, winnerId])
}

model HallOfFame {
  id         String   @id @default(cuid())
  playerId   String
  seasonId   String
  category   String
  reason     String   @db.Text
  imageUrl   String?
  inductedAt DateTime @default(now())

  player User   @relation(fields: [playerId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])
}

model News {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  image       String?
  authorId    String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetType String
  targetId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model TournamentMatch {
  id           String   @id @default(cuid())
  tournamentId String
  round        Int
  matchNumber  Int
  bracket      String   @default("WINNERS")
  homePlayerId String?
  awayPlayerId String?
  winnerId     String?
  nextMatchId  String?
  loserMatchId String?
  resultId     String?  @unique
  scheduledDate DateTime?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament               @relation(fields: [tournamentId], references: [id])
  homePlayer User?                    @relation("HomeMatches", fields: [homePlayerId], references: [id])
  awayPlayer User?                    @relation("AwayMatches", fields: [awayPlayerId], references: [id])
  winner     User?                    @relation("WinnerMatches", fields: [winnerId], references: [id])
  result     Result?                  // ✅ NO @relation with fields/references here
}


model TournamentParticipant {
  id           String   @id @default(cuid())
  tournamentId String
  playerId     String
  seed         Int?
  eliminated   Boolean  @default(false)
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player     User       @relation(fields: [playerId], references: [id])

  @@unique([tournamentId, playerId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum SquadType {
  MAIN
  SEASONAL
  TOURNAMENT
}

enum PostType {
  GENERAL
  SQUAD_SHARE
  ACHIEVEMENT
}

enum TournamentType {
  SINGLE_ELIM
  DOUBLE_ELIM
}

enum TournamentStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum SeasonStatus {
  PRESEASON
  REGISTRATION
  FIXTURE_LOCK
  LIVE
  ENDED
  ARCHIVED
}
model Setting {
  id        String   @id @default(cuid())
  userId    String?
  category  String   // "account", "notifications", "privacy", "appearance", "competition", "league", "system", "moderation"
  key       String   // "profileVisible", "emailNotifications", etc.
  value     String   // JSON string or simple value
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, key])
}

model Backup {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("MANUAL") // MANUAL, AUTO, UPLOADED
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  size        Int      @default(0)
  filePath    String?
  version     String   @default("1.0")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  restoredAt  DateTime?
  restoredBy  String?

  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  restoreLogs RestoreLog[]
}

model RestoreLog {
  id          String   @id @default(cuid())
  backupId    String
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  startedAt   DateTime @default(now())
  completedAt DateTime?
  restoredBy  String
  details     Json?

  backup      Backup   @relation(fields: [backupId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [restoredBy], references: [id])
}

model BackupConfig {
  id          String   @id @default(cuid())
  enabled     Boolean  @default(true)
  frequency   String   @default("DAILY") // HOURLY, DAILY, WEEKLY, MONTHLY
  time        String   @default("02:00")
  keepDaily   Int      @default(7)
  keepWeekly  Int      @default(4)
  keepMonthly Int      @default(3)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  updatedAt   DateTime @updatedAt
}
model Report {
  id            String   @id @default(cuid())
  postId        String
  reporterId    String?
  reason        String   @db.Text
  status        String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  reportedUserId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter      User?    @relation("ReportReporter", fields: [reporterId], references: [id])
  reportedUser  User     @relation("ReportReportedUser", fields: [reportedUserId], references: [id])
}
model ScheduledMaintenance {
  id            String   @id @default(cuid())
  scheduledAt   DateTime
  duration      Int      @default(30) // minutes
  message       String?  @db.Text
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  triggeredAt   DateTime?
  completedAt   DateTime?
}